# VOE Dashboard Configuration
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=voedashboard
POSTGRES_USER=voe
POSTGRES_PASSWORD=change_me

# OData (VOE Mendix)
ODATA_BASE_URL=
ODATA_USERNAME=
ODATA_PASSWORD=

# FlowUp (Azure MySQL)
FLOWUP_HOST=
FLOWUP_PORT=3306
FLOWUP_DB=
FLOWUP_USER=
FLOWUP_PASSWORD=

# Sync intervals (minutes)
ODATA_SYNC_INTERVAL=5
FLOWUP_SYNC_INTERVAL=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
